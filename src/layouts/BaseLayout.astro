---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl, getDir, t } from "../i18n";
import { siteConfig } from "../config/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  contentType?: string;
  category?: string;
}

const lang = getLangFromUrl(Astro.url);
const dir = getDir(lang);
const {
  title = t("site.title", lang),
  description = t("site.description", lang),
  ogImage = "/images/og-default.jpg",
  noIndex = false,
  contentType = "page",
  category = "none",
} = Astro.props;

const gaId = siteConfig.analytics.googleAnalyticsId;
const gtmId = siteConfig.analytics.googleTagManagerId;
const cfToken = siteConfig.analytics.cloudflareToken;

const fullTitle =
  title === t("site.title", lang)
    ? title
    : `${title} | ${t("site.title", lang)}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <!-- Google Tag Manager -->
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    <!-- End Google Tag Manager -->
    <!-- Google Analytics -->
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId, lang, contentType, category }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, {
            'language': lang,
            'content_type': contentType,
            'category': category,
            'page_title': document.title,
            'page_path': window.location.pathname
          });
        </script>
      </>
    )}

    <!-- Cloudflare Web Analytics -->
    {cfToken && (
      <script is:inline defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon={`{"token": "${cfToken}"}`}></script>
    )}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&family=Inter:wght@300..800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content={lang === "fa" ? "fa_IR" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={t("site.title", lang)}
      href={`/rss-${lang}.xml`}
    />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    {gtmId && (
      <noscript>
        <iframe 
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0" 
          width="0" 
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <!-- End Google Tag Manager (noscript) -->
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Mermaid.js - Diagram Rendering -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"
    ></script>
    <script is:inline>
      const mermaidSources = new WeakMap();

      function getMermaidDiagramType(code) {
        const cleaned = String(code)
          .replace(/^\s*%%\{[\s\S]*?\}%%\s*/g, "")
          .split("\n")
          .map((line) => line.trim())
          .filter((line) => line && !line.startsWith("%%"))
          .join("\n")
          .trim();

        const firstLine = cleaned.split("\n")[0]?.trim() || "";

        if (/^flowchart\b|^graph\b/.test(firstLine)) return "flowchart";
        if (/^sequenceDiagram\b/.test(firstLine)) return "sequence";
        if (/^classDiagram\b/.test(firstLine)) return "class";
        if (/^stateDiagram(?:-v2)?\b/.test(firstLine)) return "state";
        if (/^erDiagram\b/.test(firstLine)) return "er";
        if (/^gantt\b/.test(firstLine)) return "gantt";
        if (/^journey\b/.test(firstLine)) return "journey";
        if (/^gitGraph\b/.test(firstLine)) return "gitgraph";
        if (/^pie\b/.test(firstLine)) return "pie";
        if (/^quadrantChart\b/.test(firstLine)) return "quadrant";
        if (/^requirementDiagram\b/.test(firstLine)) return "requirement";
        if (/^mindmap\b/.test(firstLine)) return "mindmap";
        if (/^timeline\b/.test(firstLine)) return "timeline";
        if (/^sankey-beta\b/.test(firstLine)) return "sankey";
        if (/^xychart-beta\b|^xychart\b/.test(firstLine)) return "xychart";
        if (/^block-beta\b|^block\b/.test(firstLine)) return "block";
        if (/^architecture-beta\b|^architecture\b/.test(firstLine)) return "architecture";
        if (/^packet-beta\b|^packet\b/.test(firstLine)) return "packet";
        if (/^kanban\b/.test(firstLine)) return "kanban";

        return "unknown";
      }

      function getMermaidConfig(isDark) {
        return {
          startOnLoad: false,
          theme: isDark ? "dark" : "default",
          securityLevel: "loose",
          fontFamily: '"Vazirmatn", "Vazir", "Tahoma", sans-serif',
          flowchart: {
            htmlLabels: true,
            useMaxWidth: true,
            curve: "basis",
          },
          sequence: { useMaxWidth: true },
          gantt: {
            useMaxWidth: true,
            titleTopMargin: 25,
            barHeight: 30,
            barGap: 6,
            topPadding: 60,
            rightPadding: 120,
            leftPadding: 150,
            gridLineStartPadding: 35,
            fontSize: 13,
            sectionFontSize: 14,
            numberSectionStyles: 4,
            axisFormat: "%Y-%m",
          },
          mindmap: { useMaxWidth: true },
          pie: { useMaxWidth: true },
          timeline: { useMaxWidth: true },
          gitGraph: { useMaxWidth: true },
          stateDiagram: { useMaxWidth: true },
          themeVariables: {
            fontFamily: '"Vazirmatn", "Vazir", "Tahoma", sans-serif',
          },
        };
      }

      function cacheMermaidSources() {
        document.querySelectorAll(".mermaid").forEach((el) => {
          if (!mermaidSources.has(el) && !el.hasAttribute("data-processed")) {
            const code = el.textContent || "";
            mermaidSources.set(el, code);
            
            // Decorative: Add diagram type as class to wrapper for CSS
            const type = getMermaidDiagramType(code);
            const wrapper = el.closest(".mermaid-wrapper");
            if (wrapper) {
              wrapper.setAttribute("data-diagram-type", type);
              wrapper.classList.add("mermaid-type-" + type);
              
              // Auto-collapse large types if not explicitly set
              if (!wrapper.hasAttribute("data-expanded") && 
                  ["gantt", "timeline", "mindmap", "block", "xychart"].includes(type)) {
                wrapper.classList.add("is-collapsed");
              }
            }
          }
        });
      }

      async function runMermaid() {
        if (typeof mermaid === "undefined") return;

        cacheMermaidSources();

        try {
          await mermaid.run({
            querySelector: ".mermaid:not([data-processed])",
          });
          document.dispatchEvent(new CustomEvent("mermaid-ready"));
        } catch (error) {
          console.error("Mermaid render error:", error);
        }
      }

      function resetMermaidDiagrams() {
        document.querySelectorAll(".mermaid").forEach((el) => {
          const code = mermaidSources.get(el);
          if (typeof code === "string") {
            el.textContent = code;
            el.removeAttribute("data-processed");
          }
        });
      }

      function initializeMermaidForCurrentTheme() {
        if (typeof mermaid === "undefined") return;
        const isDark = document.documentElement.classList.contains("dark");
        mermaid.initialize(getMermaidConfig(isDark));
      }

      // Initial execution
      if (typeof mermaid !== "undefined") {
        initializeMermaidForCurrentTheme();
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", runMermaid);
        } else {
          runMermaid();
        }
      }

      // Re-render on theme change
      const themeObserver = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (mutation.attributeName !== "class") continue;
          if (typeof mermaid === "undefined") continue;

          initializeMermaidForCurrentTheme();
          resetMermaidDiagrams();
          runMermaid();
        }
      });

      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });
    </script>

    <script>
      import "../scripts/mermaid-interact";
    </script>
  </body>
</html>
