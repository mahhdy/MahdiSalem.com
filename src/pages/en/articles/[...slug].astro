---
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";
import { shouldShowHidden } from "../../../lib/hidden";

const lang = "en";

export async function getStaticPaths() {
  const articles = await getCollection(
    "articles",
    ({ data }) => data.lang === "en" && !data.draft,
  );
  return articles.flatMap((article) => {
    const slug = article.id.replace(/^en\//, "").replace(/\.(md|mdx)$/, "");
    if (!slug) return [];
    return [
      {
        params: { slug },
        props: { article, slug },
      },
    ];
  });
}

const { article, slug: routeSlug } = Astro.props;


if (article.data.hidden && !shouldShowHidden(Astro.url)) {
  return Astro.redirect("/404");
}

const { Content } = await render(article);
const slug =
  routeSlug ??
  String(article.id ?? "")
    .replace(/^en\//, "")
    .split("/")
    .filter(Boolean)
    .at(-1) ??
  "";
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  lang={lang}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  author={article.data.author}
  categories={article.data.categories}
  tags={article.data.tags}
  coverImage={article.data.coverImage}
  imageDisplay={article.data.imageDisplay}
  interfaceSlug={article.data.interface}
  rawContent={article.body ?? ""}
  slug={slug}
  draft={article.data.draft}
  showHeader={article.data["showheader"]}
  pdfOnly={article.data.pdfOnly}
  pdfUrl={article.data.pdfUrl}
  showPdfViewer={!!article.data.pdfUrl && !article.data.pdfOnly}
  hasSlide={article.data.hasSlide}
  slideArray={article.data.slideArray}
  slideAlbums={article.data.slideAlbums}
>
  <Content />
</ArticleLayout>
