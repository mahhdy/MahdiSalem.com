---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ShareButtons from "../../../components/ShareButtons.astro";
import PDFViewer from "../../../components/PDFViewer.astro";
import MultiPDFViewer from "../../../components/MultiPDFViewer.astro";
import ImageSlider from "../../../components/ImageSlider.astro";
import WidthToggle from "../../../components/WidthToggle.astro";
import { t } from "../../../i18n";
import { getCollection, render } from "astro:content";
import { shouldShowHidden } from "../../../lib/hidden";

const lang = "en";

export async function getStaticPaths() {
  const statements = await getCollection(
    "statements",
    ({ data }) => data.lang === "en" && !data.draft,
  );
  return statements.map((s) => ({
    params: { slug: s.id.replace(/^en\//, "") },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;

if (entry.data.hidden && !shouldShowHidden(Astro.url)) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();

const typeLabels: Record<string, string> = {
  statement: "Statement",
  press: "Press Release",
  position: "Position",
};
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <WidthToggle title={entry.data.title} author="Mahdi Salem" lang={lang} />
  <article class="container-narrow py-16" data-width-container>
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span
          class="text-xs px-2.5 py-1 rounded-full bg-accent/10 text-accent dark:bg-accent-light/10 dark:text-accent-light font-medium"
          >{typeLabels[entry.data.type] ?? entry.data.type}</span
        >
        <time
          datetime={entry.data.publishDate.toISOString()}
          class="text-sm text-text-muted dark:text-text-dark-muted"
          >{dateFormatter.format(entry.data.publishDate)}</time
        >
      </div>
      <h1 class="text-3xl md:text-4xl font-bold">{entry.data.title}</h1>
    </header>
    <div class="prose statement-content">
      {
        entry.data.pdfOnly && (entry.data.pdfUrl || (entry.data.pdfArray && entry.data.pdfArray.length > 0)) && !entry.data.hasSlide ? (
          <div class="pdf-only-statement">
            <MultiPDFViewer
              pdfUrl={entry.data.pdfUrl}
              pdfArray={entry.data.pdfArray}
              title={entry.data.title}
              lang={lang}
            />
          </div>
        ) : (entry.data.pdfUrl || (entry.data.pdfArray && entry.data.pdfArray.length > 0)) || entry.data.hasSlide ? (
          <div class="statement-tabs-container">
            <div class="flex justify-center mb-6">
              <div class="inline-flex p-1 bg-surface-dim dark:bg-surface-dark-dim rounded-lg border border-border dark:border-border-dark flex-wrap justify-center">
                {!entry.data.pdfOnly && (
                  <button
                    class="statement-tab-btn active px-6 py-2.5 rounded-md text-sm font-medium transition-colors"
                    data-tab="content"
                    type="button"
                  >
                    Statement
                  </button>
                )}
                {(entry.data.pdfUrl || (entry.data.pdfArray && entry.data.pdfArray.length > 0)) && (
                  <button
                    class={`statement-tab-btn ${entry.data.pdfOnly ? "active" : ""} px-6 py-2.5 rounded-md text-sm font-medium transition-colors`}
                    data-tab="pdf"
                    type="button"
                  >
                    {t("books.pdf_tab", lang)}
                  </button>
                )}
                {entry.data.hasSlide &&
                  ((entry.data.slideArray && entry.data.slideArray.length > 0) || (entry.data.slideAlbums && entry.data.slideAlbums.length > 0)) && (
                    <button
                      class={`statement-tab-btn ${!entry.data.pdfUrl && entry.data.pdfOnly ? "active" : ""} px-6 py-2.5 rounded-md text-sm font-medium transition-colors`}
                      data-tab="slides"
                      type="button"
                    >
                      Slides
                    </button>
                  )}
              </div>
            </div>

            {!entry.data.pdfOnly && (
              <div
                id="statement-content-tab"
                class="statement-tab-content active transition-opacity duration-300"
              >
                <Content />
              </div>
            )}

            {(entry.data.pdfUrl || (entry.data.pdfArray && entry.data.pdfArray.length > 0)) && (
              <div
                id="statement-pdf-tab"
                class={`statement-tab-content ${entry.data.pdfOnly ? "active" : ""} transition-opacity duration-300`}
              >
                <MultiPDFViewer
                  pdfUrl={entry.data.pdfUrl}
                  pdfArray={entry.data.pdfArray}
                  title={entry.data.title}
                  lang={lang}
                />
              </div>
            )}

            {entry.data.hasSlide &&
              ((entry.data.slideArray && entry.data.slideArray.length > 0) || (entry.data.slideAlbums && entry.data.slideAlbums.length > 0)) && (
                <div
                  id="statement-slides-tab"
                  class={`statement-tab-content ${!entry.data.pdfUrl && entry.data.pdfOnly ? "active" : ""} transition-opacity duration-300 p-2 sm:p-4 bg-surface dark:bg-surface-dark rounded-xl border border-border dark:border-border-dark my-8`}
                >
                  <ImageSlider images={entry.data.slideArray} albums={entry.data.slideAlbums} />
                </div>
              )}
          </div>
        ) : (
          <Content />
        )
      }
    </div>
    <div class="mt-8 pt-6 border-t border-border dark:border-border-dark">
      <ShareButtons title={entry.data.title} url={articleUrl} lang={lang} />
    </div>
  </article>
</BaseLayout>

<style>
  .statement-tab-btn {
    color: var(--color-text-muted);
  }
  html.dark .statement-tab-btn {
    color: var(--color-text-dark-muted);
  }
  .statement-tab-btn:hover {
    color: var(--color-text);
  }
  html.dark .statement-tab-btn:hover {
    color: var(--color-text-dark);
  }
  .statement-tab-btn.active {
    background-color: white;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    color: var(--color-primary);
  }
  html.dark .statement-tab-btn.active {
    background-color: var(--color-surface-dark);
    color: var(--color-primary-light);
  }
  .statement-tab-content {
    display: none;
  }
  .statement-tab-content.active {
    display: block;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabButtons = document.querySelectorAll(".statement-tab-btn");
    const tabContents = document.querySelectorAll(".statement-tab-content");

    if (tabButtons.length === 0) return;

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tab = button.getAttribute("data-tab");

        tabButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        tabContents.forEach((content) => {
          if (content.id === `statement-${tab}-tab`) {
            content.classList.add("active");
          } else {
            content.classList.remove("active");
          }
        });

        window.history.replaceState(null, "", `#${tab}`);
      });
    });

    const hash = window.location.hash.slice(1);
    if (hash === "content" || hash === "pdf" || hash === "slides") {
      const hashButton = document.querySelector(
        `.statement-tab-btn[data-tab="${hash}"]`,
      );
      if (hashButton) {
        (hashButton as HTMLElement).click();
      }
    }
  });
</script>
