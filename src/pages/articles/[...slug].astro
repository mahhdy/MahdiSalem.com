---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";
import { shouldShowHidden } from "../../lib/hidden";

const lang = "fa";

export async function getStaticPaths() {
  const articles = await getCollection(
    "articles",
    ({ data }) => data.lang === "fa",
  );

  const toRouteSlug = (entry: { slug?: string; id?: string }) => {
    const raw = String(entry.slug ?? entry.id ?? "");
    // Remove 'fa/' prefix and file extension, preserve all other segments
    return raw.replace(/^fa\//, "").replace(/\.(md|mdx)$/, "");
  };

  return articles.flatMap((article) => {
    const slug = toRouteSlug(article);
    if (!slug) return [];

    return [
      {
        params: { slug },
        props: { article, slug },
      },
    ];
  });
}

const { article, slug: routeSlug } = Astro.props;

// Hidden content guard — return 404 unless ?force=true
if (article.data.hidden && !shouldShowHidden(Astro.url)) {
  return Astro.redirect("/404");
}

const { Content, remarkPluginFrontmatter } = await render(article);
const slug =
  routeSlug ??
  String(article.id ?? "")
    .replace(/^fa\//, "")
    .split("/")
    .filter(Boolean)
    .at(-1) ??
  "";
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  lang={lang}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  author={article.data.author}
  categories={article.data.categories}
  tags={article.data.tags}
  coverImage={article.data.coverImage}
  imageDisplay={article.data.imageDisplay}
  interfaceSlug={article.data.interface}
  rawContent={article.body ?? ""}
  slug={slug}
  draft={article.data.draft}
  showHeader={article.data["showheader"]}
  pdfOnly={article.data.pdfOnly}
  pdfUrl={article.data.pdfUrl}
  pdfArray={article.data.pdfArray}
  showPdfViewer={!!(article.data.pdfUrl || (article.data.pdfArray && article.data.pdfArray.length > 0)) && !article.data.pdfOnly}
  hasSlide={article.data.hasSlide}
  slideArray={article.data.slideArray}
  slideAlbums={article.data.slideAlbums}
>
  <Content />
</ArticleLayout>
