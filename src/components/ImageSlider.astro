---
/**
 * ImageSlider Component v3.1 (Premium PhotoSwipe Integration)
 * Optimized for high-performance zooming, panning, and RTL support.
 */
import 'photoswipe/style.css';

interface Album {
  title: string;
  slides: string[];
}
interface Props {
  images?: string[];
  albums?: Album[];
}

const { images = [], albums = [] } = Astro.props;

// Use the first album's slides if regular slides is empty but albums are present
const validAlbums = (albums || []).filter(a => a.slides && a.slides.length > 0);
const hasAlbums = validAlbums.length > 0;
const initialImages = hasAlbums ? validAlbums[0].slides : (images || []);

const albumsJson = hasAlbums ? JSON.stringify(validAlbums) : null;
const uniqueId = `slider-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="image-slider-wrapper w-full mt-8 mb-12 select-none" id={uniqueId}>
  {hasAlbums && (
    <div class="slider-albums-nav flex flex-wrap gap-2 mb-6 p-2 bg-surface-dim/50 dark:bg-surface-dark-dim/50 rounded-xl border border-border dark:border-border-dark overflow-x-auto no-scrollbar" data-albums={albumsJson}>
      {validAlbums.map((album, idx) => (
        <button
          class={`album-tab-btn flex-none px-5 py-2.5 rounded-lg text-sm font-bold transition-all duration-300 border-2 select-none whitespace-nowrap ${idx === 0 
            ? 'bg-primary text-white border-primary dark:border-primary-light active-album' 
            : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark text-text-muted dark:text-text-dark-muted hover:border-primary/50'}`}
          data-index={idx}
        >
          {album.title}
        </button>
      ))}
    </div>
  )}

  <div class="premium-slider relative w-full overflow-hidden rounded-2xl shadow-xl bg-surface-dim dark:bg-surface-dark-dim aspect-[16/10] sm:aspect-[4/3] md:aspect-video group">
    <!-- Overlay Hints -->
    <div class="absolute inset-0 z-10 pointer-events-none flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
       <div class="px-4 py-2 bg-black/40 backdrop-blur-md text-white text-xs font-medium rounded-full border border-white/10 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
         Click to zoom & pan
       </div>
    </div>

    <!-- Main Track -->
    <div class="slider-track flex transition-transform duration-600 ease-[cubic-bezier(0.23,1,0.32,1)] h-full w-full cursor-zoom-in">
      {initialImages.map((img, i) => (
        <a 
          href={img}
          data-pswp-width="2500" 
          data-pswp-height="1800"
          class="slide shrink-0 w-full h-full flex items-center justify-center p-4 md:p-8 outline-none"
        >
          <img 
            src={img} 
            alt={`Slide ${i + 1}`} 
            class="max-w-full max-h-full object-contain rounded-lg drop-shadow-2xl transition-transform duration-500 hover:scale-[1.02]" 
            loading={i === 0 ? 'eager' : 'lazy'} 
          />
        </a>
      ))}
    </div>

    <!-- Navigation Arrows -->
    <button class="slider-prev-btn absolute left-4 top-1/2 -translate-y-1/2 z-20 p-4 rounded-full bg-black/20 backdrop-blur-md text-white hover:bg-primary opacity-0 group-hover:opacity-100 transition-all duration-300 disabled:opacity-0 focus:outline-none focus:ring-2 focus:ring-primary">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button class="slider-next-btn absolute right-4 top-1/2 -translate-y-1/2 z-20 p-4 rounded-full bg-black/20 backdrop-blur-md text-white hover:bg-primary opacity-0 group-hover:opacity-100 transition-all duration-300 disabled:opacity-0 focus:outline-none focus:ring-2 focus:ring-primary">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>

    <!-- Progress Indicator -->
    <div class="absolute top-4 left-6 z-20 flex items-center gap-2 px-3 py-1.5 bg-black/30 backdrop-blur-md rounded-lg border border-white/10 text-[10px] font-bold text-white tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity">
       <span class="current-idx">1</span> / <span class="total-count">{initialImages.length}</span>
    </div>

    <!-- Dots -->
    <div class="slider-dots absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2.5 px-4 py-2 bg-black/10 backdrop-blur-lg rounded-full border border-white/5">
      {initialImages.map((_, i) => (
        <button 
          class={`slider-dot h-2 rounded-full transition-all duration-500 ease-out ${i === 0 ? 'bg-primary dark:bg-primary-light w-8' : 'bg-white/40 hover:bg-white/70 w-2'}`} 
          data-index={i}
          aria-label={`Go to slide ${i+1}`}
        ></button>
      ))}
    </div>
  </div>
</div>

<style is:global>
  /* PhotoSwipe Customization to match brand */
  .pswp {
    --pswp-bg: rgba(0, 0, 0, 0.92);
    --pswp-placeholder-bg: #1a1a1a;
  }
  
  .pswp__button--arrow {
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(10px);
    border-radius: 50% !important;
    margin: 0 20px !important;
    width: 60px !important;
    height: 60px !important;
  }

  .pswp__button--arrow:hover {
    background: var(--color-primary, #3b82f6) !important;
  }

  /* Force LTR for PhotoSwipe UI elements to fix RTL counter and icon issues */
  .pswp__counter, 
  .pswp__ui { 
    direction: ltr !important; 
  }

  [data-lang="fa"] .image-slider-wrapper { direction: ltr; }
  [data-lang="fa"] .slider-albums-nav { direction: rtl; }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  class PremiumSlider {
    container: HTMLElement;
    track: HTMLElement | null;
    slides: NodeListOf<HTMLElement>;
    dots: NodeListOf<HTMLElement>;
    prevBtn: HTMLElement | null;
    nextBtn: HTMLElement | null;
    currentIdxEl: HTMLElement | null;
    
    currentIndex: number = 0;
    totalSlides: number = 0;
    isRtl: boolean = false;
    lightbox: any = null;

    constructor(container: HTMLElement) {
      this.container = container;
      this.track = container.querySelector('.slider-track');
      this.slides = container.querySelectorAll('.slide');
      this.dots = container.querySelectorAll('.slider-dot');
      this.prevBtn = container.querySelector('.slider-prev-btn');
      this.nextBtn = container.querySelector('.slider-next-btn');
      this.currentIdxEl = container.querySelector('.current-idx');
      
      this.totalSlides = this.slides.length;
      this.isRtl = document.documentElement.getAttribute('dir') === 'rtl';

      this.initEvents();
      this.initLightbox();
      
      // Force initial update
      this.goToSlide(0, false);
    }

    initLightbox() {
      if (this.lightbox) {
        this.lightbox.destroy();
      }

      this.lightbox = new PhotoSwipeLightbox({
        gallery: this.container.querySelector('.premium-slider'),
        children: 'a.slide',
        pswpModule: () => import('photoswipe'),
      });

      this.lightbox.on('beforeOpen', () => {
        this.lightbox.options.index = this.currentIndex;
      });

      this.lightbox.on('change', () => {
        if (this.lightbox.pswp) {
          this.goToSlide(this.lightbox.pswp.currIndex, false);
        }
      });

      this.lightbox.init();
    }

    initEvents() {
      // Clear old listeners if any (though scripts in Astro usually run once)
      this.prevBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.goToSlide(this.isRtl ? this.currentIndex + 1 : this.currentIndex - 1);
      });

      this.nextBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.goToSlide(this.isRtl ? this.currentIndex - 1 : this.currentIndex + 1);
      });

      this.dots.forEach((dot, i) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          this.goToSlide(i);
        });
      });

      // Lightbox trigger is handled automatically by PhotoSwipeLightbox for <a> children,
      // but we need to stop the default link behavior if we want to handle index sync.
      this.track?.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a.slide');
        if (link) {
          e.preventDefault();
          const index = Array.from(this.slides).indexOf(link as HTMLElement);
          this.lightbox.loadAndOpen(index);
        }
      });

      // Swipe support
      let startX = 0;
      this.container.addEventListener('touchstart', (e: any) => { startX = e.touches[0].clientX; }, {passive: true});
      this.container.addEventListener('touchend', (e: any) => {
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 50) {
          this.goToSlide(diff > 0 ? (this.isRtl ? this.currentIndex - 1 : this.currentIndex + 1) : (this.isRtl ? this.currentIndex + 1 : this.currentIndex - 1));
        }
      }, {passive: true});
    }

    goToSlide(index: number, animate = true) {
      if (index < 0) index = this.totalSlides - 1;
      if (index >= this.totalSlides) index = 0;
      
      this.currentIndex = index;
      
      if (this.track) {
        const offset = (this.isRtl ? 1 : -1) * 100 * this.currentIndex;
        this.track.style.transition = animate ? 'transform 0.6s cubic-bezier(0.23, 1, 0.32, 1)' : 'none';
        this.track.style.transform = `translateX(${offset}%)`;
      }

      if (this.currentIdxEl) this.currentIdxEl.textContent = (this.currentIndex + 1).toString();

      this.dots.forEach((dot, i) => {
        const isActive = i === this.currentIndex;
        dot.classList.toggle('bg-primary', isActive);
        dot.classList.toggle('w-8', isActive);
        dot.classList.toggle('bg-white/40', !isActive);
        dot.classList.toggle('w-2', !isActive);
      });
    }

    updateImages(newImages: string[]) {
      if (!this.track) return;
      
      this.track.innerHTML = newImages.map((img, i) => `
        <a href="${img}" data-pswp-width="2500" data-pswp-height="1800" class="slide shrink-0 w-full h-full flex items-center justify-center p-4 md:p-8 outline-none">
          <img src="${img}" alt="Slide ${i+1}" class="max-w-full max-h-full object-contain rounded-lg drop-shadow-2xl transition-transform duration-500 hover:scale-[1.02]" loading="${i === 0 ? 'eager' : 'lazy'}" />
        </a>
      `).join('');
      
      this.slides = this.container.querySelectorAll('.slide');
      this.totalSlides = this.slides.length;
      
      const totalCountEl = this.container.querySelector('.total-count');
      if (totalCountEl) totalCountEl.textContent = this.totalSlides.toString();

      // Update dots
      const dotsContainer = this.container.querySelector('.slider-dots');
      if (dotsContainer) {
        dotsContainer.innerHTML = newImages.map((_, i) => `
          <button class="slider-dot h-2 rounded-full transition-all duration-500 ${i === 0 ? 'bg-primary w-8' : 'bg-white/40 w-2'}" data-index="${i}"></button>
        `).join('');
        this.dots = dotsContainer.querySelectorAll('.slider-dot');
      }
      
      this.initLightbox();
      this.initEvents(); // Re-bind events to new dots/slides
      this.goToSlide(0, false);
    }
  }

  const initSliders = () => {
    document.querySelectorAll('.image-slider-wrapper').forEach(wrapper => {
      // Prevent multiple initializations
      if ((wrapper as any)._sliderInit) return;
      (wrapper as any)._sliderInit = true;

      const ps = new PremiumSlider(wrapper as HTMLElement);
      
      const nav = wrapper.querySelector('.slider-albums-nav') as HTMLElement;
      if (nav) {
        const albums = JSON.parse(nav.dataset.albums || '[]');
        nav.querySelectorAll('.album-tab-btn').forEach((btn, idx) => {
          btn.addEventListener('click', () => {
            nav.querySelectorAll('.album-tab-btn').forEach(b => {
              b.classList.remove('bg-primary', 'text-white', 'active-album', 'border-primary');
              b.classList.add('bg-surface', 'dark:bg-surface-dark', 'border-border', 'dark:border-border-dark');
            });
            btn.classList.add('bg-primary', 'text-white', 'active-album', 'border-primary');
            btn.classList.remove('bg-surface', 'dark:bg-surface-dark', 'border-border', 'dark:border-border-dark');
            ps.updateImages(albums[idx].slides);
          });
        });
      }
    });
  };

  // Run on initial load
  initSliders();

  // Support for Astro View Transitions if added
  document.addEventListener('astro:page-load', initSliders);
</script>
