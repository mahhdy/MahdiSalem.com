---
/**
 * ImageSlider Component v2.1 (Full Standalone Premium Version)
 * Optimized for MDX frontmatter integration.
 */
interface Album {
  title: string;
  slides: string[];
}
interface Props {
  images?: string[];
  albums?: Album[];
}

const { images = [], albums = [] } = Astro.props;

// Use the first album's slides if regular slides is empty but albums are present
const validAlbums = (albums || []).filter(a => a.slides && a.slides.length > 0);
const hasAlbums = validAlbums.length > 0;
const validImages = hasAlbums ? validAlbums[0].slides : (images || []);

const albumsJson = hasAlbums ? JSON.stringify(validAlbums) : null;
---

<div class="image-slider-wrapper w-full mt-8 mb-12">
  {hasAlbums && (
    <div class="slider-albums-nav flex flex-wrap gap-2 mb-6 p-2 bg-surface-dim/50 dark:bg-surface-dark-dim/50 rounded-xl border border-border dark:border-border-dark overflow-x-auto no-scrollbar" data-albums={albumsJson}>
      {validAlbums.map((album, idx) => (
        <button
          class={`album-tab-btn flex-none px-5 py-2.5 rounded-lg text-sm font-bold transition-all duration-300 border-2 select-none whitespace-nowrap ${idx === 0 
            ? 'bg-primary text-white border-primary dark:border-primary-light active-album' 
            : 'bg-surface dark:bg-surface-dark border-border dark:border-border-dark text-text-muted dark:text-text-dark-muted hover:border-primary/50'}`}
          data-index={idx}
        >
          {album.title}
        </button>
      ))}
    </div>
  )}

  <div class="premium-slider relative w-full overflow-hidden rounded-2xl shadow-xl bg-surface-dim dark:bg-surface-dark-dim aspect-[16/10] sm:aspect-[4/3] md:aspect-video group" id="main-slider">
    <!-- Top actions -->
    <div class="absolute top-4 right-4 z-20 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
       <button class="slider-expand-btn p-3 rounded-xl bg-black/40 backdrop-blur-md text-white hover:bg-black/60 transition-all border border-white/20" title="Full Screen">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
       </button>
    </div>

    <button class="slider-close-btn hidden fixed top-6 right-6 z-[60] p-4 rounded-2xl bg-black/40 backdrop-blur-xl text-white hover:bg-primary transition-all border border-white/20">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>

    <!-- Main Track -->
    <div class="slider-track flex transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] h-full w-full">
      {validImages.map((img, i) => (
        <div class="slide shrink-0 w-full h-full flex items-center justify-center p-4">
          <img 
            src={img} 
            alt={`Slide ${i + 1}`} 
            class="max-w-full max-h-full object-contain rounded-lg drop-shadow-[0_8px_24px_rgba(0,0,0,0.15)]" 
            loading={i === 0 ? 'eager' : 'lazy'} 
          />
        </div>
      ))}
    </div>

    <!-- Navigation Arrows -->
    <button class="slider-prev-btn absolute left-4 top-1/2 -translate-y-1/2 z-20 p-4 rounded-full bg-black/20 backdrop-blur-md text-white hover:bg-primary opacity-0 group-hover:opacity-100 transition-all duration-300 disabled:opacity-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button class="slider-next-btn absolute right-4 top-1/2 -translate-y-1/2 z-20 p-4 rounded-full bg-black/20 backdrop-blur-md text-white hover:bg-primary opacity-0 group-hover:opacity-100 transition-all duration-300 disabled:opacity-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>

    <!-- Fullscreen Controls (Only visible in fullscreen) -->
    <div class="slider-fs-controls absolute bottom-10 left-1/2 -translate-x-1/2 z-50 hidden flex items-center gap-4 p-2 bg-black/40 backdrop-blur-xl rounded-2xl border border-white/10">
       <button class="zoom-out-btn p-3 text-white hover:text-primary transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7" /></svg></button>
       <button class="zoom-reset-btn px-4 text-xs font-bold text-white uppercase tracking-widest hover:text-primary transition-colors">Reset</button>
       <button class="zoom-in-btn p-3 text-white hover:text-primary transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" /></svg></button>
    </div>

    <!-- Dots -->
    <div class="slider-dots absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2.5 px-4 py-2 bg-black/10 backdrop-blur-lg rounded-full border border-white/5">
      {validImages.map((_, i) => (
        <button 
          class={`slider-dot h-2.5 rounded-full transition-all duration-300 ease-out shadow-inner ${i === 0 ? 'bg-primary dark:bg-primary-light w-8' : 'bg-white/50 hover:bg-white/80 w-2.5'}`} 
          data-index={i}
          aria-label={`Go to slide ${i+1}`}
        ></button>
      ))}
    </div>
  </div>
</div>

<style is:global>
  .premium-slider.is-fullscreen {
    position: fixed !important;
    inset: 0 !important;
    z-index: 1000 !important;
    width: 100vw !important;
    height: 100vh !important;
    background: #000 !important;
    border-radius: 0 !important;
    margin: 0 !important;
  }
  .premium-slider.is-fullscreen .slider-track { height: 100%; width: 100%; }
  .premium-slider.is-fullscreen .slider-close-btn { display: block !important; }
  .premium-slider.is-fullscreen .slider-fs-controls { display: flex !important; }
  .premium-slider.is-fullscreen .slider-expand-btn { display: none !important; }
  
  .slide.is-zoomed { cursor: grab; }
  .slide.is-dragging { cursor: grabbing; }
  
  [data-lang="fa"] .image-slider-wrapper { direction: ltr; }
  [data-lang="fa"] .slider-albums-nav { direction: rtl; }
</style>

<script>
  import Panzoom from '@panzoom/panzoom';

  class PremiumSlider {
    container: HTMLElement;
    track: HTMLElement | null;
    slides: NodeListOf<Element>;
    dots: NodeListOf<Element>;
    prevBtn: HTMLElement | null;
    nextBtn: HTMLElement | null;
    expandBtn: HTMLElement | null;
    closeBtn: HTMLElement | null;
    zoomInBtn: HTMLElement | null;
    zoomOutBtn: HTMLElement | null;
    zoomResetBtn: HTMLElement | null;
    
    currentIndex: number = 0;
    totalSlides: number = 0;
    isFullscreen: boolean = false;
    isRtl: boolean = false;
    panzooms: Map<HTMLElement, any> = new Map();

    constructor(container: HTMLElement) {
      this.container = container;
      this.track = container.querySelector('.slider-track');
      this.slides = container.querySelectorAll('.slide');
      this.dots = container.querySelectorAll('.slider-dot');
      this.prevBtn = container.querySelector('.slider-prev-btn');
      this.nextBtn = container.querySelector('.slider-next-btn');
      this.expandBtn = container.querySelector('.slider-expand-btn');
      this.closeBtn = container.querySelector('.slider-close-btn');
      this.zoomInBtn = container.querySelector('.zoom-in-btn');
      this.zoomOutBtn = container.querySelector('.zoom-out-btn');
      this.zoomResetBtn = container.querySelector('.zoom-reset-btn');
      
      this.totalSlides = this.slides.length;
      
      const dir = document.documentElement.getAttribute('dir') || 'ltr';
      this.isRtl = dir === 'rtl';

      this.initEvents();
      this.initPanzoom();
    }

    initPanzoom() {
      // Clear old panzooms
      this.panzooms.forEach(pz => pz.destroy());
      this.panzooms.clear();

      this.slides.forEach((slide) => {
        const img = slide.querySelector('img');
        if (img) {
          // Initialize Panzoom on EACH image
          // @ts-ignore
          const pz = Panzoom(img, {
            maxScale: 6,
            minScale: 1,
            contain: 'outside',
            step: 0.3,
            handleStartEvent: (event: any) => {
              if (event.touches && event.touches.length > 1) return true;
              if (!this.isFullscreen && pz.getScale() === 1) return false;
              event.preventDefault();
              return true;
            }
          });
          
          this.panzooms.set(slide as HTMLElement, pz);

          // Wheel zoom
          img.parentElement?.addEventListener('wheel', (event: any) => {
            if (this.isFullscreen || pz.getScale() > 1) {
              pz.zoomWithWheel(event);
            }
          }, { passive: false });

          // Double click/tap zoom
          let lastClickTime = 0;
          img.addEventListener('click', (e: MouseEvent) => {
            const currentTime = new Date().getTime();
            if (currentTime - lastClickTime < 300) {
              e.preventDefault();
              pz.getScale() > 1 ? pz.reset() : pz.zoomIn();
            }
            lastClickTime = currentTime;
          });
        }
      });
    }

    initEvents() {
      this.prevBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.goToSlide(this.isRtl ? this.currentIndex + 1 : this.currentIndex - 1);
      });
      this.nextBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        this.goToSlide(this.isRtl ? this.currentIndex - 1 : this.currentIndex + 1);
      });

      this.dots.forEach((dot: Element, i: number) => {
        (dot as HTMLElement).onclick = () => this.goToSlide(i);
      });

      this.expandBtn?.addEventListener('click', () => this.openFullscreen());
      this.closeBtn?.addEventListener('click', () => this.closeFullscreen());

      this.zoomInBtn?.addEventListener('click', () => {
        const pz = this.panzooms.get(this.slides[this.currentIndex] as HTMLElement);
        pz?.zoomIn();
      });
      this.zoomOutBtn?.addEventListener('click', () => {
        const pz = this.panzooms.get(this.slides[this.currentIndex] as HTMLElement);
        pz?.zoomOut();
      });
      this.zoomResetBtn?.addEventListener('click', () => {
        const pz = this.panzooms.get(this.slides[this.currentIndex] as HTMLElement);
        pz?.reset();
      });

      // Key events
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') this.closeFullscreen();
        if (e.key === 'ArrowRight') this.goToSlide(this.isRtl ? this.currentIndex - 1 : this.currentIndex + 1);
        if (e.key === 'ArrowLeft') this.goToSlide(this.isRtl ? this.currentIndex + 1 : this.currentIndex - 1);
      });

      // Swipe
      let startX = 0;
      this.container.addEventListener('touchstart', (e: any) => { startX = e.touches[0].clientX; }, {passive: true});
      this.container.addEventListener('touchend', (e: any) => {
        const endX = e.changedTouches[0].clientX;
        if (Math.abs(startX - endX) > 50) {
          this.goToSlide(startX > endX ? (this.isRtl ? this.currentIndex - 1 : this.currentIndex + 1) : (this.isRtl ? this.currentIndex + 1 : this.currentIndex - 1));
        }
      }, {passive: true});
    }

    goToSlide(index: number) {
      if (index < 0) index = this.totalSlides - 1;
      if (index >= this.totalSlides) index = 0;
      
      const oldPz = this.panzooms.get(this.slides[this.currentIndex] as HTMLElement);
      if (oldPz?.getScale() > 1) oldPz.reset();

      this.currentIndex = index;
      if (this.track) {
        const offset = (this.isRtl ? 1 : -1) * 100 * this.currentIndex;
        this.track.style.transform = `translateX(${offset}%)`;
      }

      this.dots.forEach((dot, i) => {
        dot.classList.toggle('bg-primary', i === this.currentIndex);
        dot.classList.toggle('w-8', i === this.currentIndex);
        dot.classList.toggle('bg-white/50', i !== this.currentIndex);
        dot.classList.toggle('w-2.5', i !== this.currentIndex);
      });
    }

    updateImages(newImages: string[]) {
      if (!this.track) return;
      this.track.innerHTML = newImages.map((img, i) => `
        <div class="slide shrink-0 w-full h-full flex items-center justify-center p-4">
          <img src="${img}" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" loading="${i === 0 ? 'eager' : 'lazy'}" />
        </div>
      `).join('');
      
      this.slides = this.container.querySelectorAll('.slide');
      this.totalSlides = this.slides.length;
      this.initPanzoom();
      
      // Update dots
      const dotsContainer = this.container.querySelector('.slider-dots');
      if (dotsContainer) {
        dotsContainer.innerHTML = newImages.map((_, i) => `
          <button class="slider-dot h-2.5 rounded-full transition-all ${i === 0 ? 'bg-primary w-8' : 'bg-white/50 w-2.5'}" data-index="${i}"></button>
        `).join('');
        this.dots = dotsContainer.querySelectorAll('.slider-dot');
        this.dots.forEach((dot, i) => (dot as HTMLElement).onclick = () => this.goToSlide(i));
      }
      
      this.goToSlide(0);
    }

    openFullscreen() {
      this.isFullscreen = true;
      this.container.classList.add('is-fullscreen');
      document.body.style.overflow = 'hidden';
    }

    closeFullscreen() {
      this.isFullscreen = false;
      this.container.classList.remove('is-fullscreen');
      document.body.style.overflow = '';
      this.panzooms.forEach(pz => pz.reset());
    }
  }

  const init = () => {
    document.querySelectorAll('.premium-slider').forEach(slider => {
      const ps = new PremiumSlider(slider as HTMLElement);
      
      // If there's an album nav, link it
      const nav = slider.parentElement?.querySelector('.slider-albums-nav') as HTMLElement;
      if (nav) {
        const albums = JSON.parse(nav.dataset.albums || '[]');
        nav.querySelectorAll('.album-tab-btn').forEach((btn, idx) => {
          btn.addEventListener('click', () => {
            nav.querySelectorAll('.album-tab-btn').forEach(b => b.classList.remove('bg-primary', 'text-white', 'active-album'));
            btn.classList.add('bg-primary', 'text-white', 'active-album');
            ps.updateImages(albums[idx].slides);
          });
        });
      }
    });
  };

  document.addEventListener('astro:page-load', init);
  document.addEventListener('DOMContentLoaded', init);
</script>
