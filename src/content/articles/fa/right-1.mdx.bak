        </tr>
      </thead>
      <tbody>
        {rows.map((row, ri) => (
          <tr key={ri}>
            {row.map((cell, ci) => (
              <td key={ci} style={{
                padding: '0.8rem 1rem',
                background: ri % 2 === 0 ? '#ffffff' : '#f8f9fa',
                color: '#333',
                lineHeight: 1.8,
                borderBottom: '1px solid #eee',
                textAlign: 'right',
              }}>{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
    {caption && (
      <p style={{ textAlign: 'center', color: '#555', fontSize: '0.83rem', marginTop: '0.6rem', fontStyle: 'italic' }}>
        {caption}
      </p>
    )}
  </div>
);

