export const Callout = ({ type = 'info', title, children }) => {
  const config = {
    info: { bg: '#e8f4fd', border: '#2196F3', titleColor: '#1565C0', icon: '💡' },
    warning: { bg: '#fff8e1', border: '#FF9800', titleColor: '#E65100', icon: '⚠️' },
    quote: { bg: '#f3e5f5', border: '#9C27B0', titleColor: '#6A1B9A', icon: '💬' },
    critical: { bg: '#fce4ec', border: '#E53935', titleColor: '#B71C1C', icon: '🔍' },
    success: { bg: '#e8f5e9', border: '#4CAF50', titleColor: '#2E7D32', icon: '✅' },
  };
  const c = config[type] || config.info;
  return (
    <div style={{
      background: c.bg,
      borderRight: `5px solid ${c.border}`,
      borderRadius: '8px',
      padding: '1.2rem 1.5rem',
      marginBottom: '1.5rem',
      direction: 'rtl',
    }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.6rem' }}>
        <span style={{ fontSize: '1.2rem' }}>{c.icon}</span>
        <strong style={{ color: c.titleColor, fontSize: '1rem' }}>{title}</strong>
      </div>
      <div style={{ color: '#333', lineHeight: 2, fontSize: '0.95rem' }}>{children}</div>
    </div>
  );
};

