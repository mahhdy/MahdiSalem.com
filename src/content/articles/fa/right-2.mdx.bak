          <stop offset="0%" stopColor="#E65100"/><stop offset="100%" stopColor="#BF360C"/>
        </linearGradient>
        <linearGradient id="midGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#2E7D32"/><stop offset="100%" stopColor="#1B5E20"/>
        </linearGradient>
