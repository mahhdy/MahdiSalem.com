)

export const Callout = ({ type = 'info', title, children }) => {
  const styles = {
    info:     { bg: '#e8f4fd', border: '#2196F3', icon: '💡', titleColor: '#1565C0' },
    warning:  { bg: '#fff8e1', border: '#FF9800', icon: '⚠️', titleColor: '#E65100' },
    quote:    { bg: '#f3e5f5', border: '#9C27B0', icon: '💬', titleColor: '#6A1B9A' },
    critical: { bg: '#fce4ec', border: '#E53935', icon: '🔍', titleColor: '#B71C1C' },
    success:  { bg: '#e8f5e9', border: '#4CAF50', icon: '✅', titleColor: '#2E7D32' },
    keypoint: { bg: '#e3f2fd', border: '#1976D2', icon: '🔑', titleColor: '#0D47A1' },
    critique: { bg: '#fce4ec', border: '#C62828', icon: '⚖️', titleColor: '#B71C1C' },
    example:  { bg: '#e8f5e9', border: '#388E3C', icon: '📝', titleColor: '#1B5E20' }
  }
  const s = styles[type] || styles.info
  return (
    <div style={{
      background: s.bg,
      borderRight: `5px solid ${s.border}`,
      borderRadius: '8px',
      padding: '1.2rem 1.5rem',
      margin: '1.5rem 0',
      direction: 'rtl'
    }}>
      {title && (
        <div style={{ fontWeight: '700', color: s.titleColor, marginBottom: '0.5rem', fontSize: '1.05rem' }}>
          {s.icon} {title}
        </div>
      )}
      <div style={{ color: '#333', lineHeight: '2' }}>{children}</div>
    </div>
  )
}

export const QuoteBlock = ({ text, author, source }) => (
  <div style={{
    background: 'linear-gradient(135deg, #faf5ff 0%, #f0e6ff 100%)',
    border: '1px solid #d4b5ff',
    borderRadius: '12px',
    padding: '2rem',
    margin: '2rem 0',
    textAlign: 'center',
    position: 'relative',
    direction: 'rtl'
  }}>
    <svg width="36" height="28" viewBox="0 0 40 32" style={{ position: 'absolute', top: '14px', right: '18px', opacity: 0.12 }}>
      <path d="M0 20.8C0 27.2 4 32 10.4 32c4.8 0 8-3.2 8-7.2 0-4-2.8-6.8-6.4-6.8-1.2 0-2 .4-2.8.8C10 12 14.4 5.6 18.4 3.2L14.4 0C6 4.8 0 13.6 0 20.8zm21.6 0C21.6 27.2 25.6 32 32 32c4.8 0 8-3.2 8-7.2 0-4-2.8-6.8-6.4-6.8-1.2 0-2.4.4-2.8.8C31.6 12 36 5.6 40 3.2L36 0c-8.4 4.8-14.4 13.6-14.4 20.8z" fill="#6A1B9A"/>
    </svg>
    <p style={{ fontSize: '1.1rem', fontStyle: 'italic', color: '#4a148c', lineHeight: '2.2', margin: '0 0 0.8rem' }}>
      «{text}»
    </p>
    {author && <p style={{ color: '#6A1B9A', fontWeight: '700', margin: 0 }}>— {author}{source && `، ${source}`}</p>}
  </div>
)

export const SectionDivider = ({ icon = '◆', label }) => (
  <div style={{ textAlign: 'center', margin: '3rem 0 2rem' }}>
    <div style={{ color: '#999', fontSize: '1.2rem', letterSpacing: '0.5rem' }}>─── {icon} ───</div>
    {label && <div style={{ color: '#555', fontSize: '0.85rem', marginTop: '0.3rem' }}>{label}</div>}
  </div>
)

export const NumberedCard = ({ number, title, children }) => (
  <div style={{
    display: 'flex',
    gap: '1rem',
    margin: '1rem 0',
    padding: '1.2rem',
    background: '#f8f9fa',
    borderRadius: '10px',
    direction: 'rtl',
    alignItems: 'flex-start'
  }}>
    <div style={{
      minWidth: '38px', height: '38px',
      background: 'linear-gradient(135deg, #e94560, #c23152)',
      borderRadius: '50%',
      display: 'flex', alignItems: 'center', justifyContent: 'center',
      color: 'white', fontWeight: '800', fontSize: '0.95rem', flexShrink: 0
    }}>{number}</div>
    <div>
      {title && <strong style={{ color: '#1a1a2e', display: 'block', marginBottom: '0.3rem' }}>{title}</strong>}
      <div style={{ color: '#444', lineHeight: '2' }}>{children}</div>
    </div>
  </div>
)

export const KeywordBadges = ({ items }) => (
  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem', justifyContent: 'center', margin: '1rem 0 2rem', direction: 'rtl' }}>
    {items.map((item, i) => (
      <span key={i} style={{
        background: 'linear-gradient(135deg, #e8eaf6, #c5cae9)',
        color: '#283593',
        padding: '6px 14px',
        borderRadius: '20px',
        fontSize: '0.85rem',
        fontWeight: '600'
      }}>{item}</span>
    ))}
  </div>
)

export const DataTable = ({ headers, rows, caption, highlightFirst = false }) => (
  <div style={{ margin: '1.5rem 0', direction: 'rtl' }}>
    <div style={{ overflowX: 'auto', borderRadius: '10px', boxShadow: '0 2px 12px rgba(0,0,0,0.07)' }}>
      <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '0.9rem' }}>
        <thead>
          <tr style={{ background: 'linear-gradient(135deg, #29417a, #1a2a5e)' }}>
            {headers.map((h, i) => (
              <th key={i} style={{ color: 'white', padding: '12px 16px', textAlign: 'right', fontWeight: '700', fontSize: '0.88rem' }}>{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr key={i} style={{ background: i % 2 === 0 ? '#f8f9fa' : 'white', borderBottom: '1px solid #e9ecef' }}>
              {row.map((cell, j) => (
                <td key={j} style={{
                  padding: '11px 16px',
                  textAlign: 'right',
                  lineHeight: '1.9',
                  fontWeight: (highlightFirst && j === 0) ? '600' : 'normal',
                  color: (highlightFirst && j === 0) ? '#1a1a2e' : '#444'
                }}>{cell}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {caption && <p style={{ textAlign: 'center', color: '#666', fontSize: '0.82rem', marginTop: '0.6rem' }}>📊 {caption}</p>}
  </div>
)

export const ConclusionCard = ({ number, title, children }) => (
  <div style={{
    background: 'linear-gradient(135deg, #1a1a2e, #16213e)',
    borderRadius: '12px',
    padding: '1.5rem',
    margin: '1rem 0',
    direction: 'rtl',
    display: 'flex',
    gap: '1.2rem',
    alignItems: 'flex-start'
  }}>
    <div style={{
      minWidth: '42px', height: '42px',
      background: 'linear-gradient(135deg, #e94560, #ff6b6b)',
      borderRadius: '10px',
      display: 'flex', alignItems: 'center', justifyContent: 'center',
      color: 'white', fontWeight: '900', fontSize: '1.1rem', flexShrink: 0
    }}>{number}</div>
    <div>
      <strong style={{ color: '#64ffda', display: 'block', marginBottom: '0.4rem', fontSize: '1rem' }}>{title}</strong>
      <p style={{ color: '#e8e8e8', lineHeight: '2', margin: 0 }}>{children}</p>
    </div>
  </div>
)

export const FootnoteRef = ({ id, children }) => (
  <sup style={{ color: '#e94560', cursor: 'help', fontWeight: '700' }} title={children}>[{id}]</sup>
)

export const Footnote = ({ id, children }) => (
  <div style={{ fontSize: '0.85rem', color: '#555', padding: '0.3rem 0', borderBottom: '1px solid #eee', direction: 'rtl' }}>
    <span style={{ color: '#e94560', fontWeight: '700' }}>[{id}]</span> {children}
  </div>
)

export const ChapterHeader = ({ number, title, id }) => (
  <div id={id} style={{
    background: 'linear-gradient(135deg, #29417a, #1a2a5e)',
    borderRadius: '12px',
    padding: '1.8rem 2rem',
    margin: '2.5rem 0 1.5rem',
    direction: 'rtl',
    position: 'relative',
    overflow: 'hidden'
  }}>
    <svg viewBox="0 0 400 80" style={{ position: 'absolute', top: 0, right: 0, width: '40%', height: '100%', opacity: 0.06 }}>
      <circle cx="350" cy="40" r="60" fill="white"/>
      <circle cx="300" cy="20" r="30" fill="white"/>
    </svg>
    <div style={{ position: 'relative', zIndex: 1 }}>
      {number && <span style={{ color: '#64ffda', fontSize: '0.85rem', fontWeight: '600', display: 'block', marginBottom: '0.3rem' }}>فصل {number}</span>}
      <h2 style={{ color: 'white', margin: 0, fontSize: '1.5rem', fontWeight: '800' }}>{title}</h2>
    </div>
  </div>
)

export const AppendixSection = ({ id, title, icon, children }) => (
  <div style={{
    margin: '2rem 0',
    border: '1px solid #e0e0e0',
    borderRadius: '14px',
    overflow: 'hidden',
    direction: 'rtl'
  }}>
    <div style={{
      background: 'linear-gradient(135deg, #37474f, #263238)',
      padding: '1rem 1.5rem',
      display: 'flex',
      alignItems: 'center',
      gap: '0.8rem'
    }}>
      <span style={{ fontSize: '1.4rem' }}>{icon}</span>
      <h3 style={{ color: 'white', margin: 0, fontSize: '1.1rem' }} id={id}>{title}</h3>
    </div>
    <div style={{ padding: '1.5rem' }}>{children}</div>
  </div>
)

