export const HohfeldSVG = () => (
  <div style={{ textAlign: 'center', margin: '2rem 0' }}>
    <svg viewBox="0 0 520 420" width="100%" style={{ maxWidth: '480px' }}>
      <defs>
        <linearGradient id="hf1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#e3f2fd"/><stop offset="100%" stopColor="#bbdefb"/>
        </linearGradient>
        <linearGradient id="hf2" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#fce4ec"/><stop offset="100%" stopColor="#f8bbd0"/>
        </linearGradient>
        <linearGradient id="hf3" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#e8f5e9"/><stop offset="100%" stopColor="#c8e6c9"/>
        </linearGradient>
        <linearGradient id="hf4" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#fff3e0"/><stop offset="100%" stopColor="#ffe0b2"/>
        </linearGradient>
        <filter id="hfShadow"><feDropShadow dx="0" dy="3" stdDeviation="5" floodOpacity="0.12"/></filter>
      </defs>
      <text x="260" y="28" textAnchor="middle" fontSize="15" fontWeight="bold" fill="#1a1a2e">چارچوب چهارگانه‌ی هوفلد</text>
      {/* کارت ادعا */}
      <rect x="30" y="55" width="210" height="140" rx="14" fill="url(#hf1)" stroke="#1976D2" strokeWidth="1.5" filter="url(#hfShadow)"/>
      <text x="135" y="88" textAnchor="middle" fontSize="24">📋</text>
      <text x="135" y="115" textAnchor="middle" fontSize="14" fontWeight="bold" fill="#0D47A1">ادّعا</text>
      <text x="135" y="135" textAnchor="middle" fontSize="10" fill="#333">Claim-Right</text>
      <text x="135" y="160" textAnchor="middle" fontSize="9.5" fill="#444">↔ تکلیف متناظر (Duty)</text>
      <text x="135" y="180" textAnchor="middle" fontSize="9" fill="#555">A حق دارد، B وظیفه دارد</text>
      {/* کارت امتیاز */}
      <rect x="280" y="55" width="210" height="140" rx="14" fill="url(#hf2)" stroke="#C62828" strokeWidth="1.5" filter="url(#hfShadow)"/>
      <text x="385" y="88" textAnchor="middle" fontSize="24">🔓</text>
      <text x="385" y="115" textAnchor="middle" fontSize="14" fontWeight="bold" fill="#B71C1C">امتیاز / آزادی</text>
      <text x="385" y="135" textAnchor="middle" fontSize="10" fill="#333">Privilege / Liberty</text>
      <text x="385" y="160" textAnchor="middle" fontSize="9.5" fill="#444">↔ نبودِ ادعا (No-Claim)</text>
      <text x="385" y="180" textAnchor="middle" fontSize="9" fill="#555">A مجاز است، B ادعایی ندارد</text>
      {/* کارت قدرت */}
      <rect x="30" y="225" width="210" height="140" rx="14" fill="url(#hf3)" stroke="#388E3C" strokeWidth="1.5" filter="url(#hfShadow)"/>
      <text x="135" y="258" textAnchor="middle" fontSize="24">⚡</text>
      <text x="135" y="285" textAnchor="middle" fontSize="14" fontWeight="bold" fill="#1B5E20">قدرت حقوقی</text>
      <text x="135" y="305" textAnchor="middle" fontSize="10" fill="#333">Power</text>
      <text x="135" y="330" textAnchor="middle" fontSize="9.5" fill="#444">↔ تعرض‌پذیری (Liability)</text>
      <text x="135" y="350" textAnchor="middle" fontSize="9" fill="#555">A می‌تواند وضع B را تغییر دهد</text>
      {/* کارت مصونیت */}
      <rect x="280" y="225" width="210" height="140" rx="14" fill="url(#hf4)" stroke="#E65100" strokeWidth="1.5" filter="url(#hfShadow)"/>
      <text x="385" y="258" textAnchor="middle" fontSize="24">🛡️</text>
      <text x="385" y="285" textAnchor="middle" fontSize="14" fontWeight="bold" fill="#E65100">مصونیت</text>
      <text x="385" y="305" textAnchor="middle" fontSize="10" fill="#333">Immunity</text>
      <text x="385" y="330" textAnchor="middle" fontSize="9.5" fill="#444">↔ ناتوانی (Disability)</text>
      <text x="385" y="350" textAnchor="middle" fontSize="9" fill="#555">B نمی‌تواند وضع A را تغییر دهد</text>
      {/* خطوط ارتباط */}
      <line x1="240" y1="125" x2="280" y2="125" stroke="#666" strokeWidth="1.5" strokeDasharray="5,3"/>
      <line x1="240" y1="295" x2="280" y2="295" stroke="#666" strokeWidth="1.5" strokeDasharray="5,3"/>
      <line x1="135" y1="195" x2="135" y2="225" stroke="#666" strokeWidth="1.5" strokeDasharray="5,3"/>
      <line x1="385" y1="195" x2="385" y2="225" stroke="#666" strokeWidth="1.5" strokeDasharray="5,3"/>
      <text x="260" y="405" textAnchor="middle" fontSize="10" fill="#666" fontStyle="italic">هر معنای «حق» باید مشخص شود تا از خلط مفاهیم جلوگیری شود</text>
    </svg>
  </div>
)

export const ConceptMapSVG = () => (
  <div style={{ textAlign: 'center', margin: '2rem 0' }}>
    <svg viewBox="0 0 650 500" width="100%" style={{ maxWidth: '600px' }}>
      <defs>
        <filter id="cmShadow"><feDropShadow dx="0" dy="2" stdDeviation="4" floodOpacity="0.1"/></filter>
        <radialGradient id="centerGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stopColor="#e94560" stopOpacity="0.15"/>
          <stop offset="100%" stopColor="#e94560" stopOpacity="0"/>
        </radialGradient>
      </defs>
      <text x="325" y="25" textAnchor="middle" fontSize="15" fontWeight="bold" fill="#1a1a2e">نقشه‌ی مفهومی حق</text>
      {/* هاله مرکزی */}
      <circle cx="325" cy="260" r="120" fill="url(#centerGlow)"/>
      {/* مرکز */}
      <circle cx="325" cy="260" r="42" fill="#1a1a2e" filter="url(#cmShadow)"/>
      <text x="325" y="256" textAnchor="middle" fontSize="20" fill="white" fontWeight="bold">حق</text>
      <text x="325" y="275" textAnchor="middle" fontSize="9" fill="#64ffda">Right</text>
      {/* مفاهیم اطراف */}
      {[
        { x: 325, y: 80, label: 'عدالت', en: 'Justice', color: '#1565C0', bg: '#e3f2fd' },
        { x: 520, y: 130, label: 'آزادی', en: 'Liberty', color: '#C62828', bg: '#fce4ec' },
        { x: 590, y: 260, label: 'برابری', en: 'Equality', color: '#6A1B9A', bg: '#f3e5f5' },
        { x: 520, y: 390, label: 'قدرت', en: 'Power', color: '#E65100', bg: '#fff3e0' },
        { x: 325, y: 440, label: 'کرامت', en: 'Dignity', color: '#2E7D32', bg: '#e8f5e9' },
        { x: 130, y: 390, label: 'مسئولیت', en: 'Responsibility', color: '#00695C', bg: '#e0f2f1' },
        { x: 60, y: 260, label: 'قانون', en: 'Law', color: '#4E342E', bg: '#efebe9' },
        { x: 130, y: 130, label: 'اخلاق', en: 'Morality', color: '#37474F', bg: '#eceff1' },
      ].map((c, i) => (
        <g key={i}>
          <line x1="325" y1="260" x2={c.x} y2={c.y} stroke={c.color} strokeWidth="1.2" strokeDasharray="6,3" opacity="0.4"/>
          <rect x={c.x - 52} y={c.y - 22} width="104" height="44" rx="22" fill={c.bg} stroke={c.color} strokeWidth="1.2" filter="url(#cmShadow)"/>
          <text x={c.x} y={c.y - 3} textAnchor="middle" fontSize="11" fontWeight="bold" fill={c.color}>{c.label}</text>
          <text x={c.x} y={c.y + 13} textAnchor="middle" fontSize="8" fill="#555">{c.en}</text>
        </g>
      ))}
    </svg>
  </div>
)

export const OntologySVG = () => (
